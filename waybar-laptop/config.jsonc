{
	"position": "top",
	"height": 23,
	"modules-left": [
        "custom/logo",
        "cpu",
        "memory",
        "disk"
	],
	"modules-center": [
        "niri/window",
		"tray"
	],
	"modules-right": [
		"network",
        "bluetooth",
        "niri/language",
		"pulseaudio",
        "backlight",
        "battery",
        "clock"
	],
	"clock": {
		"format": "{:%H:%M %p}",
		"interval": 30
	},
	"niri/window": {
		"format": "{}",
		"rewrite": {
            "": "(à¸‡ â€¢ج€_â€¢جپ)à¸‡",
			"(.*) â€” Mozilla Firefox": "Firefox",
			"v (.*)": "neovim",
            "discord.com/app.*": "Discord"
		},
		"separate-outputs": true,
		"icon": true
	},
	"niri/workspaces": {
		"persistent-workspaces": {"*": 5},
		"format": "{icon}"
	},
	"custom/logo": {
		"format": " َ°£‡ "
	},
    "custom/divisor": {
        "format": " َ°‡™ "
    },
	"tray": {
        	"icon-size": 20,
        	"spacing": 10,
        	"show-passive-items": false
    	},
    	"memory": {
    		"interval": 5,
		"format": " ïƒ‰ {percentage}% "
    	},
    	"cpu": {
		"interval": 5,
		"format": "îˆ´ {usage}%"
    	},
    	"disk": {
		"interval": 60,
		"format": "ïƒ‡ {percentage_used}%"
    	},
	"network": {
        	"interval": 1,
        	"tooltip": false,
        	"format-wifi": "ï‡«  on",
        	"format-disconnected": " َ°–ھ",
        	"on-click": "kitty -e nmtui"
    	},
	"pulseaudio": {
        	"format": "ï€¨  {volume}%",
        	"tooltip": false,
        	"format-muted": "Muted î»¨ ",
        	"on-click": "pavucontrol",
        	"scroll-step": 5
	},
    "battery": {
        //"bat": "BAT2",
        "interval": 60,
        "format": "{icon} {capacity}% ",
        "format-icons": {
            "default": ["َ°‚ژ ", "َ°پ؛ ", "َ°پ» ", "َ°پ¼ ", "َ°پ½ ", "َ°پ¾ ", "َ°پ؟ ", "َ°‚€ ", "َ°‚پ ", "َ°‚‚ ", "َ°پ¹ "],
            "charging": ["َ°¢ں ", "َ°¢œ ", "َ°‚† ", "َ°‚‡ ", "َ°‚ˆ ", "َ°¢‌ ", "َ°‚‰ ", "َ°¢‍ ", "َ°‚ٹ ", "َ°‚‹ ", "َ°‚… "]
        }
    },
    "bluetooth": {
    	"format": " ïٹ” on",
    	"format-disabled": " َ°‚² off", 
    	"format-connected": " َ°‚± con",
    	"tooltip-format": "{controller_alias}\t{controller_address}",
    	"tooltip-format-connected": "{controller_alias}\t{controller_address}\n\n{device_enumerate}",
    	"tooltip-format-enumerate-connected": "{device_alias}\t{device_address}"
    },
    "niri/language": {
    	"format": "{}",
    	"format-en": "ï†«  en",
    	"format-de": "ï†«  de"
    },
    "backlight": {
    	"device": "intel_backlight",
    	"format": "{icon} {percent}% ",
    	"format-icons": ["ï†…", "َ°ƒ "]
    }
}


